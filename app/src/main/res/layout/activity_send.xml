<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enviar Arquivos"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSelectFiles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selecionar Arquivos"
        android:layout_marginBottom="16dp"
        app:icon="@android:drawable/ic_menu_add" />

    <TextView
        android:id="@+id/tvFileCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 arquivo(s) selecionado(s)"
        android:textSize="16sp"
        android:textColor="@color/primary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvFileList"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:text=""
        android:textSize="14sp"
        android:scrollbars="vertical"
        android:padding="12dp"
        android:background="@drawable/card_background"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnScanQR"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Escanear QR Code do Receptor"
        android:layout_marginBottom="16dp"
        app:icon="@android:drawable/ic_menu_camera" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enviar Arquivos"
        android:layout_marginBottom="16dp"
        app:icon="@android:drawable/ic_menu_upload" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Voltar"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

</LinearLayout>
