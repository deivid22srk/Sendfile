<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_upload"
            android:layout_marginBottom="16dp"
            android:contentDescription="App Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Transfira arquivos rapidamente entre dispositivos Android"
            android:textSize="16sp"
            android:textColor="@color/secondary_text"
            android:gravity="center"
            android:layout_marginBottom="48dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Enviar Arquivos"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"
            app:icon="@drawable/ic_upload"
            app:iconGravity="textStart"
            app:iconSize="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReceive"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Receber Arquivos"
            android:textSize="18sp"
            app:icon="@drawable/ic_download"
            app:iconGravity="textStart"
            app:iconSize="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sem bluetooth necessário\nTransferência via WiFi local (alta velocidade)"
            android:textSize="14sp"
            android:textColor="@color/hint_text"
            android:gravity="center"
            android:layout_marginTop="32dp" />

    </LinearLayout>
</ScrollView>
